# PostgreSQL
POSTGRES_DB=todo_app
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=<strong-password>
DATABASE_URL=postgres://todo_user:<strong-password>@postgres:5432/todo_app?sslmode=disable

# Redis
REDIS_PASSWORD=<strong-redis-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Elasticsearch
ELASTIC_PASSWORD=<strong-elastic-password>
ELASTICSEARCH_URL=http://elastic:<strong-elastic-password>@elasticsearch:9200

# JWT
JWT_SECRET=<min-32-char-random-secret>

# Internal service auth
INTERNAL_API_KEY=<random-api-key>

# GitHub Container Registry
GITHUB_ORG=<your-github-org>

# Service versions (git SHA or semver tag)
AUTH_SERVICE_VERSION=latest
TODO_SERVICE_VERSION=latest
FILE_SERVICE_VERSION=latest
NOTIFICATION_SERVICE_VERSION=latest
SCHEDULER_SERVICE_VERSION=latest

# Observability
GRAFANA_ADMIN_PASSWORD=<strong-grafana-password>

# Logging
LOG_LEVEL=info

# Let's Encrypt
LETSENCRYPT_EMAIL=<your-email>
DOMAIN=<your-domain>
